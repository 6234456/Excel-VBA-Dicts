    Debug.Print "TestDicts_IsNothing passed"
End Sub


' =====================================================================
' SECTION 21 – HashSets: basic operations
' Currently zero HashSets tests exist in the test suite.
' =====================================================================
Public Sub TestHashSets_BasicOps()
    Dim h As New HashSets

    Debug.Assert h.Count = 0
    Debug.Assert h.isEmpty          ' Note: isEmpty reads pLen which must be 0

    h.add 5
    h.add 10
    h.add 3
    h.add 10                        ' duplicate – should be ignored

    Debug.Assert h.Count = 3
    Debug.Assert h.contains(5)
    Debug.Assert h.contains(10)
    Debug.Assert h.contains(3)
    Debug.Assert Not h.contains(99)

    ' first / last follow insertion order
    Debug.Assert h.first = 5
    Debug.Assert h.last = 3

    ' toArray has correct length
    Debug.Assert UBound(h.toArray) - LBound(h.toArray) + 1 = 3

    ' Remove
    h.Remove 10
    Debug.Assert h.Count = 2
    Debug.Assert Not h.contains(10)

    ' Remove non-existent element is a no-op
    h.Remove 99
    Debug.Assert h.Count = 2

    ' addAll
    h.clear
    h.addAll 1, 2, 3, 2, 1
    Debug.Assert h.Count = 3

    Debug.Print "TestHashSets_BasicOps passed"
End Sub


' =====================================================================
' SECTION 22 – HashSets: duplicate rejection
' =====================================================================
Public Sub TestHashSets_DuplicateRejection()
    Dim h As New HashSets

    Dim addResult As Boolean
    addResult = h.add(7)
    Debug.Assert addResult = True   ' first add -> True

    addResult = h.add(7)
    Debug.Assert addResult = False  ' duplicate -> False

    Debug.Assert h.Count = 1

    Debug.Print "TestHashSets_DuplicateRejection passed"
End Sub


' =====================================================================
' SECTION 23 – TreeSets: pollFirst() / pollLast()
' Remove-and-return the minimum / maximum element.
' =====================================================================
Public Sub TestTreeSets_PollFirstLast()
    Dim t As New TreeSets

    t.addAll 5, 3, 8, 1, 7

    ' pollFirst removes and returns the smallest
    Dim smallest As Variant
    smallest = t.pollFirst
    Debug.Assert smallest = 1
    Debug.Assert t.Count = 4
    Debug.Assert Not t.contains(1)

    ' pollLast removes and returns the largest
    Dim largest As Variant
    largest = t.pollLast
    Debug.Assert largest = 8
    Debug.Assert t.Count = 3
    Debug.Assert Not t.contains(8)

    Debug.Print "TestTreeSets_PollFirstLast passed"
End Sub


