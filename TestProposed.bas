' =====================================================================
' SECTION 1 – Lists: Statistical operations
' Currently untested: min_(), max_(), avg()
' =====================================================================
Public Sub TestLists_StatisticalOps()
    Dim l As New Lists

    ' min_
    Debug.Assert l.fromSerial(3, 7).min_ = 3
    Debug.Assert l.fromArray(Array(10, 2, 7, 1, 5)).min_ = 1

    ' max_
    Debug.Assert l.fromSerial(3, 7).max_ = 7
    Debug.Assert l.fromArray(Array(10, 2, 7, 1, 5)).max_ = 10

    ' avg
    Debug.Assert l.fromArray(Array(1, 2, 3, 4, 5)).avg = 3

    ' single-element edge cases
    Debug.Assert l.fromArray(Array(42)).min_ = 42
    Debug.Assert l.fromArray(Array(42)).max_ = 42
    Debug.Assert l.fromArray(Array(42)).avg = 42

    Debug.Print "TestLists_StatisticalOps passed"
End Sub


' =====================================================================
' SECTION 2 – Lists: slice / take / drop / dropLast
' These are used internally (e.g. inside removeAt) but never directly
' asserted in the existing test suite.
' =====================================================================
Public Sub TestLists_SliceTakeDrop()
    Dim l As New Lists

    ' slice with explicit indices
    Debug.Assert l.fromSerial(1, 5).slice(1, 3).length = 2          ' [2, 3]
    Debug.Assert l.fromSerial(1, 5).slice(1, 3).getVal(0) = 2

    ' negative index: slice from the end
    Debug.Assert l.fromSerial(1, 5).slice(-2).length = 2            ' [4, 5]
    Debug.Assert l.fromSerial(1, 5).slice(-2).getVal(0) = 4

    ' take
    Debug.Assert l.fromSerial(1, 10).take(3).length = 3
    Debug.Assert l.fromSerial(1, 10).take(3).getVal(2) = 3

    ' drop
    Debug.Assert l.fromSerial(1, 5).drop(2).length = 3
    Debug.Assert l.fromSerial(1, 5).drop(2).getVal(0) = 3

    ' dropLast
    Debug.Assert l.fromSerial(1, 5).dropLast(2).length = 3
    Debug.Assert l.fromSerial(1, 5).dropLast(2).getVal(2) = 3

    ' take(0) -> empty list
    Debug.Assert l.fromSerial(1, 5).take(0).length = 0

    Debug.Print "TestLists_SliceTakeDrop passed"
End Sub


' =====================================================================
' SECTION 3 – Lists: indexOf
' True and false (not-found) cases are both unverified.
' =====================================================================
Public Sub TestLists_IndexOf()
    Dim l As New Lists
    Set l = l.fromSerial(10, 15)

    ' present element returns correct 0-based index
    Debug.Assert l.indexOf(10) = 0
    Debug.Assert l.indexOf(12) = 2
    Debug.Assert l.indexOf(15) = 5

    ' absent element returns -1
    Debug.Assert l.indexOf(99) = -1
    Debug.Assert l.indexOf(9) = -1

    ' contains false case (not verified in existing tests)
    Debug.Assert Not l.contains(99)

    Debug.Print "TestLists_IndexOf passed"
End Sub


' =====================================================================
' SECTION 4 – Lists: some() / every()
' =====================================================================
Public Sub TestLists_SomeEvery()
    Dim l As New Lists

    ' some – at least one element matches
    Debug.Assert l.fromSerial(1, 5).some("_>4")     ' 5 > 4
    Debug.Assert Not l.fromSerial(1, 5).some("_>10")

    ' every – all elements match
    Debug.Assert l.fromSerial(1, 5).every("_>0")
    Debug.Assert Not l.fromSerial(1, 5).every("_>2")

    ' edge: single element
    Debug.Assert l.of(7).some("_=7")
    Debug.Assert l.of(7).every("_>0")

    Debug.Print "TestLists_SomeEvery passed"
End Sub


' =====================================================================
' SECTION 5 – Lists: zip() / zipMe() / flatten()
' zip() is used to build test data for fromMatrix but is never directly
' asserted.  flatten() and zipMe() are completely untested.
' =====================================================================
Public Sub TestLists_ZipAndFlatten()
    Dim l As New Lists
    Dim a As New Lists
    Dim b As New Lists

    ' zip two lists into list-of-pairs
    Set a = l.fromSerial(1, 3)
    Set b = l.fromSerial(4, 6)
    With a.zip(b)
        Debug.Assert .length = 3
        Debug.Assert .getVal(0, 0) = 1
        Debug.Assert .getVal(0, 1) = 4
        Debug.Assert .getVal(2, 0) = 3
        Debug.Assert .getVal(2, 1) = 6
    End With

    ' flatten: [[1,2],[3,4]] -> [1,2,3,4]
    Dim nested As New Lists
    nested.add l.of(1, 2)
    nested.add l.of(3, 4)
    With nested.flatten
        Debug.Assert .length = 4
        Debug.Assert .getVal(0) = 1
        Debug.Assert .getVal(3) = 4
    End With

    ' zipMe (transpose a list-of-lists)
    Dim matrix As New Lists
    matrix.add l.of(1, 2, 3)
    matrix.add l.of(4, 5, 6)
    With matrix.zipMe
        Debug.Assert .length = 3               ' 3 columns -> 3 rows after transpose
        Debug.Assert .getVal(0, 0) = 1
        Debug.Assert .getVal(0, 1) = 4
    End With

    Debug.Print "TestLists_ZipAndFlatten passed"
End Sub


' =====================================================================
' SECTION 6 – Lists: string utilities (fromString / join)
' =====================================================================
Public Sub TestLists_StringOps()
    Dim l As New Lists

    ' fromString: every character becomes an element
    With l.fromString("hello")
        Debug.Assert .length = 5
        Debug.Assert .getVal(0) = "h"
        Debug.Assert .getVal(4) = "o"
    End With

    ' join: concatenate with delimiter
    Debug.Assert l.fromSerial(1, 3).join(",") = "1,2,3"
    Debug.Assert l.fromArray(Array("a", "b", "c")).join("-") = "a-b-c"

    ' join with empty delimiter
    Debug.Assert l.fromString("abc").join("") = "abc"

    Debug.Print "TestLists_StringOps passed"
End Sub


' =====================================================================
' SECTION 7 – Lists: in-place mutation (addAt, removeAt, repeat)
' =====================================================================
Public Sub TestLists_Mutation()
    Dim l As New Lists

    ' addAt – insert at position
    l.fromSerial(1, 3).addAt 99, 1
    ' [1, 99, 2, 3]  length = 4
    Debug.Assert l.length = 4
    Debug.Assert l.getVal(1) = 99
    Debug.Assert l.getVal(2) = 2

    ' removeAt – remove by position
    l.fromSerial(1, 5).removeAt 2
    ' [1, 2, 4, 5]
    Debug.Assert l.length = 4
    Debug.Assert l.getVal(2) = 4

    ' repeat – create list with repeated value
    With l.repeat(7, 4)
        Debug.Assert .length = 4
        Debug.Assert .getVal(0) = 7
        Debug.Assert .getVal(3) = 7
    End With

    Debug.Print "TestLists_Mutation passed"
End Sub


' =====================================================================
' SECTION 8 – Lists: reduceRight()
' Reduces from the right; order matters for non-commutative operations.
' =====================================================================
Public Sub TestLists_ReduceRight()
    Dim l As New Lists

    ' For subtraction: right-fold [1,2,3] with (acc - cur) from the right
    ' reduceRight("?-_", 0): 0 - 3 = -3; -3 - 2 = -5; -5 - 1 = -6
    Debug.Assert l.fromArray(Array(1, 2, 3)).reduceRight("?-_", 0) = -6

    ' Sanity: for commutative operation result should be same as reduce
    Debug.Assert l.fromArray(Array(1, 2, 3, 4)).reduceRight("?+_", 0) = _
                 l.fromArray(Array(1, 2, 3, 4)).reduce("?+_", 0)

    Debug.Print "TestLists_ReduceRight passed"
End Sub


' =====================================================================
' SECTION 9 – Lists: product()
' Element-wise operation between two lists; completely untested.
' =====================================================================
Public Sub TestLists_Product()
    Dim l As New Lists

    ' element-wise multiply
    With l.fromArray(Array(1, 2, 3)).product("_*?", l.fromArray(Array(4, 5, 6)))
        Debug.Assert .length = 3
        Debug.Assert .getVal(0) = 4
        Debug.Assert .getVal(1) = 10
        Debug.Assert .getVal(2) = 18
    End With

    ' mismatched lengths: stops at shorter list
    With l.fromSerial(1, 5).product("_+?", l.fromSerial(1, 3))
        Debug.Assert .length = 3
    End With

    Debug.Print "TestLists_Product passed"
End Sub


