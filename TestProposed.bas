' =====================================================================
' SECTION 11 – Dicts: intersect()
' Returns only keys that exist in both dicts.
' =====================================================================
Public Sub TestDicts_Intersect()
    Dim d1 As New Dicts
    Dim d2 As New Dicts
    Dim l As New Lists

    d1.add 1, "a" : d1.add 2, "b" : d1.add 3, "c"
    d2.add 2, "x" : d2.add 3, "y" : d2.add 4, "z"

    With d1.intersect(d2)
        Debug.Assert .Count = 2
        Debug.Assert .exists(2)
        Debug.Assert .exists(3)
        Debug.Assert Not .exists(1)
        Debug.Assert Not .exists(4)
        ' by default keeps value from d1 (keepOriginalVal = True)
        Debug.Assert .Item(2) = "b"
    End With

    ' keepOriginalVal = False -> use values from d2
    With d1.intersect(d2, False)
        Debug.Assert .Item(2) = "x"
    End With

    ' empty intersection
    Dim d3 As New Dicts
    d3.add 9, "z"
    Debug.Assert d1.intersect(d3).Count = 0

    Debug.Print "TestDicts_Intersect passed"
End Sub


' =====================================================================
' SECTION 12 – Dicts: update()
' Like union but always overwrites with new values.
' =====================================================================
Public Sub TestDicts_Update()
    Dim d1 As New Dicts
    Dim d2 As New Dicts

    d1.add 1, "old1" : d1.add 2, "old2"
    d2.add 2, "new2" : d2.add 3, "new3"

    With d1.update(d2)
        Debug.Assert .Count = 3
        ' key 2 should be overwritten by d2's value
        Debug.Assert .Item(2) = "new2"
        ' key 1 stays from d1
        Debug.Assert .Item(1) = "old1"
        ' key 3 added from d2
        Debug.Assert .Item(3) = "new3"
    End With

    Debug.Print "TestDicts_Update passed"
End Sub


' =====================================================================
' SECTION 13 – Dicts: leftJoin()
' Keys from left dict; values from both, with a default for missing keys.
' =====================================================================
Public Sub TestDicts_LeftJoin()
    Dim d1 As New Dicts
    Dim d2 As New Dicts

    d1.add "A", 1 : d1.add "B", 2 : d1.add "C", 3
    d2.add "A", 10 : d2.add "C", 30

    With d1.leftJoin(d2)
        Debug.Assert .Count = 3                      ' only left-dict keys
        ' "A" exists in both -> values concatenated into a list
        Debug.Assert .Item("A").length = 2
        Debug.Assert .Item("A").getVal(0) = 1
        Debug.Assert .Item("A").getVal(1) = 10
        ' "B" missing from d2 -> padded with default (0)
        Debug.Assert .Item("B").length = 2
        Debug.Assert .Item("B").getVal(1) = 0
        ' "C" exists in both
        Debug.Assert .Item("C").getVal(1) = 30
    End With

    ' custom default for missing keys
    With d1.leftJoin(d2, defaultByNull:=-1)
        Debug.Assert .Item("B").getVal(1) = -1
    End With

    Debug.Print "TestDicts_LeftJoin passed"
End Sub


' =====================================================================
' SECTION 14 – Dicts: frequencyCount()
' Counts occurrences of each element in an array/collection.
' =====================================================================
Public Sub TestDicts_FrequencyCount()
    Dim d As New Dicts

    With d.frequencyCount(Array("a", "b", "a", "c", "a", "b"))
        Debug.Assert .Count = 3
        Debug.Assert .Item("a") = 3
        Debug.Assert .Item("b") = 2
        Debug.Assert .Item("c") = 1
    End With

    ' all unique values -> each count = 1
    With d.frequencyCount(Array(1, 2, 3, 4, 5))
        Debug.Assert .Count = 5
        Debug.Assert .Item(1) = 1
    End With

    ' single repeated value
    With d.frequencyCount(Array("x", "x", "x"))
        Debug.Assert .Count = 1
        Debug.Assert .Item("x") = 3
    End With

    Debug.Print "TestDicts_FrequencyCount passed"
End Sub


' =====================================================================
' SECTION 15 – Dicts: nulls()
' Removes empty-valued entries (or replaces them).
' =====================================================================
Public Sub TestDicts_Nulls()
    Dim d As New Dicts

    d.add 1, 10
    d.add 2, Empty     ' empty value
    d.add 3, 30
    d.add 4, Empty

    ' without argument: remove empty entries
    With d.nulls()
        Debug.Assert .Count = 2
        Debug.Assert .exists(1)
        Debug.Assert .exists(3)
        Debug.Assert Not .exists(2)
        Debug.Assert Not .exists(4)
    End With

    ' reset dict and re-add for second sub-test
    d.clear
    d.add 1, 10 : d.add 2, Empty : d.add 3, 30

    ' with toVal: replace empty entries with the specified value
    With d.nulls(toVal:=0)
        Debug.Assert .Count = 3
        Debug.Assert .Item(2) = 0
    End With

    Debug.Print "TestDicts_Nulls passed"
End Sub


' =====================================================================
' SECTION 16 – Dicts: Remove()
' Remove a key and verify it is no longer present.
' =====================================================================
Public Sub TestDicts_Remove()
    Dim d As New Dicts

    d.add 1, "a" : d.add 2, "b" : d.add 3, "c"
    d.Remove 2

    Debug.Assert d.Count = 2
    Debug.Assert Not d.exists(2)
    Debug.Assert IsNull(d.Item(2))    ' non-existent key returns Null
    Debug.Assert d.exists(1)
    Debug.Assert d.exists(3)

    ' removing a non-existent key should not raise an error
    d.Remove 99
    Debug.Assert d.Count = 2

    Debug.Print "TestDicts_Remove passed"
End Sub


' =====================================================================
' SECTION 17 – Dicts: union(keepOriginalVal:=False)
' The existing test only uses the default (keepOriginalVal = True).
' =====================================================================
Public Sub TestDicts_UnionKeepOriginalFalse()
    Dim d1 As New Dicts
    Dim d2 As New Dicts

    d1.add 1, "original" : d1.add 2, "original2"
    d2.add 2, "override" : d2.add 3, "new"

    ' keepOriginalVal = True (default): d1's value for key 2 is preserved
    Debug.Assert d1.union(d2, True).Item(2) = "original2"

    ' keepOriginalVal = False: d2's value for key 2 wins
    Debug.Assert d1.union(d2, False).Item(2) = "override"

    Debug.Print "TestDicts_UnionKeepOriginalFalse passed"
End Sub


' =====================================================================
' SECTION 18 – Dicts: Count(recursive:=True)
' Counts keys at all nesting levels.
' =====================================================================
Public Sub TestDicts_RecursiveCount()
    Dim outer As New Dicts
    Dim inner As New Dicts

    inner.add "x", 1 : inner.add "y", 2
    outer.add "A", inner
    outer.add "B", inner

    ' non-recursive: 2 top-level keys
    Debug.Assert outer.Count = 2

    ' recursive, allLevels = True: 2 parents + 2*2 children = 6
    Debug.Assert outer.Count(True, True) = 6

    ' recursive, allLevels = False: only leaf nodes = 4
    Debug.Assert outer.Count(True, False) = 4

    Debug.Print "TestDicts_RecursiveCount passed"
End Sub


' =====================================================================
' SECTION 19 – Dicts: Label operations
' hasLabel, setLabel with Array, copyLabel, label after clear
' =====================================================================
Public Sub TestDicts_LabelOps()
    Dim d As New Dicts
    Dim d2 As New Dicts

    Debug.Assert Not d.hasLabel

    d.add 1, Array(10, 20, 30)
    d.label = Array("col0", "col1", "col2")

    Debug.Assert d.hasLabel
    Debug.Assert d.getByLabel(1, "col1") = 20

    ' copyLabel
    d.copyLabel d, d2
    Debug.Assert d2.hasLabel

    ' setLabel with Nothing clears label
    d.setLabel Nothing
    Debug.Assert Not d.hasLabel

    Debug.Print "TestDicts_LabelOps passed"
End Sub


' =====================================================================
' SECTION 20 – Dicts: isNothing() – false case
' The existing test only checks isNothing("123") = False.
